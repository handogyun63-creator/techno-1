            </div>
            <div class="rounded-[32px] border border-slate-200 bg-white p-8 shadow-sm">${sectionTitle("Live preview", "등록 공고 예시", "채용공고가 실제 플랫폼에서 어떻게 보일지를 카드 형태로 보여줍니다.")}<div class="mt-6 grid xl:grid-cols-2 gap-4">${sampleJobs.map(job => `<div class="rounded-[28px] border border-slate-200 bg-slate-50 p-5 shadow-sm"><div class="text-lg font-bold text-slate-900">${job.title}</div><div class="mt-1 text-sm text-slate-500">${job.company}</div><div class="mt-3 text-sm leading-6 text-slate-600">${job.description}</div></div>`).join("")}</div></div>
          </div>
