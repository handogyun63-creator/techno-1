      function mainContent() {
        if (state.role === "student") {
          if (state.studentPage === "dashboard") return studentDashboard();
          if (state.studentPage === "jobs") return studentJobsPage();
          if (state.studentPage === "documents") return studentDocumentsPage();
          return studentApplicationsPage();
        }
        if (state.employerPage === "dashboard") return employerDashboard();
        if (state.employerPage === "post") return employerJobPostPage();
        return employerApplicantsPage();
      }

      function render() {
        app.innerHTML = `
          <header class="sticky top-0 z-40 border-b border-slate-200/80 bg-white/90 backdrop-blur">
            <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between gap-4">
              <div class="flex items-center gap-3"><div class="h-11 w-11 rounded-2xl bg-emerald-500 text-white flex items-center justify-center font-bold shadow-sm">K</div><div><div class="font-bold tracking-tight">K-Student Work Bridge</div><div class="text-xs text-slate-500">외국인 유학생 전용 구인구직·서류지원 프로토타입</div></div></div>
              <div class="hidden md:flex items-center gap-2 rounded-full border border-slate-200 bg-slate-100 p-1"><button data-role="employer" class="px-4 py-2 rounded-full text-sm font-medium transition ${state.role === "employer" ? "bg-white text-slate-900 shadow-sm" : "text-slate-500"}">고용주</button><button data-role="student" class="px-4 py-2 rounded-full text-sm font-medium transition ${state.role === "student" ? "bg-white text-slate-900 shadow-sm" : "text-slate-500"}">외국인 유학생</button></div>
              <div class="flex items-center gap-2"><div class="hidden lg:flex items-center gap-1 rounded-full border border-slate-200 bg-slate-100 p-1 mr-2">${languageOptions.map(lang => `<button data-language="${lang}" class="px-3 py-1.5 rounded-full text-xs font-semibold ${state.language === lang ? "bg-white text-slate-900 shadow-sm" : "text-slate-500"}">${lang}</button>`).join("")}</div><button class="rounded-full border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700">로그인</button><button class="rounded-full bg-emerald-500 px-4 py-2 text-sm font-semibold text-white">회원가입</button></div>
            </div>
          </header>

          ${generatedFilesPanel()}

          <main>
            <section class="max-w-7xl mx-auto px-6 pt-10 pb-8">
              <div class="grid lg:grid-cols-[1.15fr_0.85fr] gap-8 items-stretch">
                <div class="rounded-[32px] bg-gradient-to-br from-emerald-500 via-emerald-600 to-teal-700 p-8 md:p-10 text-white shadow-xl">
                  <div class="inline-flex items-center gap-2 rounded-full bg-white/15 px-3 py-1 text-xs font-semibold tracking-wide">Cloudflare Direct Upload Ready · ${state.language}</div>
                  <h1 class="mt-5 text-4xl md:text-5xl font-black leading-tight tracking-tight">외국인 유학생 채용과<br />시간제취업 서류 준비를<br />한 곳에서.</h1>
                  <p class="mt-5 max-w-2xl text-sm md:text-base leading-7 text-emerald-50">이 버전은 단일 index.html 파일로 동작하도록 바꾼 Cloudflare Pages Direct Upload용 정적 버전입니다.</p>
                  <div class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-3">${statCard("활성 공고 예시", "128", "emerald")}${statCard("문서 출력", "PDF + ZIP")}${statCard("배포 방식", "Single HTML")}</div>
                </div>
                <div class="space-y-4">${statCard("회원 유형", "고용주 · 외국인 유학생")}${statCard("핵심 가치", "채용 + 행정서류 연결", "slate")}<div class="rounded-[32px] border border-slate-200 bg-white p-6 md:p-8 shadow-sm"><div class="text-sm font-semibold text-slate-500">배포 메모</div><div class="mt-5 space-y-4"><div class="rounded-2xl border border-slate-100 bg-slate-50 p-4 text-sm text-slate-700">이 파일 하나를 <span class="font-semibold">index.html</span> 이름으로 저장한 뒤 Cloudflare Pages Direct Upload에 올리면 됩니다.</div><div class="rounded-2xl border border-slate-100 bg-slate-50 p-4 text-sm text-slate-700">별도 빌드 없이 정적 사이트로 동작합니다.</div></div></div></div>
              </div>
            </section>

            <section class="max-w-7xl mx-auto px-6 pb-6">
              <div class="flex flex-wrap gap-3">
                ${state.role === "student"
                  ? `<button data-student-page="dashboard" class="rounded-full px-4 py-2 text-sm font-semibold ${state.studentPage === "dashboard" ? "bg-slate-900 text-white" : "bg-white border border-slate-300 text-slate-700"}">학생 대시보드</button>
                     <button data-student-page="jobs" class="rounded-full px-4 py-2 text-sm font-semibold ${state.studentPage === "jobs" ? "bg-slate-900 text-white" : "bg-white border border-slate-300 text-slate-700"}">공고 탐색</button>
                     <button data-student-page="documents" class="rounded-full px-4 py-2 text-sm font-semibold ${state.studentPage === "documents" ? "bg-slate-900 text-white" : "bg-white border border-slate-300 text-slate-700"}">서류 준비</button>
                     <button data-student-page="applications" class="rounded-full px-4 py-2 text-sm font-semibold ${state.studentPage === "applications" ? "bg-slate-900 text-white" : "bg-white border border-slate-300 text-slate-700"}">지원 현황</button>`
                  : `<button data-employer-page="dashboard" class="rounded-full px-4 py-2 text-sm font-semibold ${state.employerPage === "dashboard" ? "bg-slate-900 text-white" : "bg-white border border-slate-300 text-slate-700"}">고용주 대시보드</button>
                     <button data-employer-page="post" class="rounded-full px-4 py-2 text-sm font-semibold ${state.employerPage === "post" ? "bg-slate-900 text-white" : "bg-white border border-slate-300 text-slate-700"}">공고 등록</button>
                     <button data-employer-page="applicants" class="rounded-full px-4 py-2 text-sm font-semibold ${state.employerPage === "applicants" ? "bg-slate-900 text-white" : "bg-white border border-slate-300 text-slate-700"}">지원자 관리</button>`}
              </div>
            </section>

            <section class="max-w-7xl mx-auto px-6 pb-16">${mainContent()}</section>
          </main>
        `;

        bindEvents();
      }

      function bindEvents() {
        document.querySelectorAll("[data-role]").forEach((el) => el.onclick = () => setState({ role: el.dataset.role }));
        document.querySelectorAll("[data-language]").forEach((el) => el.onclick = () => setState({ language: el.dataset.language }));
        document.querySelectorAll("[data-student-page]").forEach((el) => el.onclick = () => setState({ studentPage: el.dataset.studentPage }));
        document.querySelectorAll("[data-employer-page]").forEach((el) => el.onclick = () => setState({ employerPage: el.dataset.employerPage }));
        document.querySelectorAll("[data-select-job]").forEach((el) => el.onclick = () => setState({ selectedJobId: Number(el.dataset.selectJob) }));
        document.querySelectorAll("[data-check-key]").forEach((el) => el.onclick = () => {
          state.studentCheck[el.dataset.checkKey] = el.dataset.checkValue === "true";
          render();
        });
        document.querySelectorAll("[data-prefix][data-key]").forEach((el) => {
          const handler = (e) => {
            const target = e.target;
            const prefix = target.dataset.prefix;
            const key = target.dataset.key;
            if (prefix === "student") state.studentForm[key] = target.value;
            if (prefix === "employer") state.employerForm[key] = target.value;
          };
          el.oninput = handler;
          el.onchange = handler;
        });
        document.querySelectorAll("[data-action='download-student-pdf']").forEach((el) => el.onclick = downloadStudentPdf);
        document.querySelectorAll("[data-action='download-employer-pdf']").forEach((el) => el.onclick = downloadEmployerPdf);
        document.querySelectorAll("[data-action='download-package']").forEach((el) => el.onclick = downloadPackageZip);
        document.querySelectorAll("[data-download-id]").forEach((el) => el.onclick = () => {
          const file = state.generatedFiles.find((f) => f.id === el.dataset.downloadId);
          if (file) downloadGeneratedFile(file);
        });
        document.querySelectorAll("[data-remove-id]").forEach((el) => el.onclick = () => removeGeneratedFile(el.dataset.removeId));
        document.querySelectorAll("[data-action='clear-files']").forEach((el) => el.onclick = clearGeneratedFiles);
      }

      render();
    </script>
  </body>
</html>
