      function employerJobPostPage() {
        return `
          <div class="space-y-8">
            <div class="rounded-[32px] border border-slate-200 bg-white p-8 shadow-sm">
              ${sectionTitle("Employer dashboard", "고용주 전용 채용공고 등록", "외국인 유학생 대상 채용 공고를 올릴 때 필요한 항목을 먼저 입력하는 화면입니다.", `<button data-action="download-package" class="rounded-full bg-slate-900 px-4 py-2 text-sm font-semibold text-white">문서 패키지 ZIP</button>`)}
